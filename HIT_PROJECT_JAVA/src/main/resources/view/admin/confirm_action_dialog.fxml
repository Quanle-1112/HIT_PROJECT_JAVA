<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="400.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.admin.ConfirmActionController">
    <children>
        <AnchorPane prefHeight="45.0" style="-fx-background-color: #19345D;">
            <children>
                <Label layoutX="14.0" layoutY="12.0" text="Xác nhận" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>

        <VBox alignment="CENTER" spacing="15.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label fx:id="lblTitle" text="Bạn có chắc chắn muốn khóa tài khoản này?" textFill="RED" wrapText="true">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <Label fx:id="lblMessage" alignment="CENTER" text="Email người dùng sẽ bị đưa vào danh sách đen." textAlignment="CENTER" textFill="#555555" wrapText="true">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>

                <HBox alignment="CENTER" spacing="20.0">
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                    <children>
                        <Button fx:id="btnCancel" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-color: #19345D; -fx-border-radius: 5; -fx-cursor: hand;" text="Hủy" textFill="#19345d">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnConfirm" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #ff0000; -fx-background-radius: 5; -fx-cursor: hand;" text="Xác nhận" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
