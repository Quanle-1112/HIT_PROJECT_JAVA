<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="450.0" style="-fx-background-color: #ECECE7;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.admin.UserManagerController">
    <children>
        <AnchorPane prefHeight="60.0" prefWidth="450.0" style="-fx-background-color: #19345D;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Button fx:id="btnBack" layoutX="10.0" layoutY="13.0" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;" text="&lt;" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Button>
                <Label layoutX="50.0" layoutY="15.0" text="Quản lý Người Dùng" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>

        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="70.0">
            <children>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <TextField fx:id="txtSearch" prefHeight="40.0" promptText="Tìm theo ID, Username, Email..." style="-fx-background-radius: 20; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </TextField>
                        <Button fx:id="btnSearch" mnemonicParsing="false" prefHeight="40.0" prefWidth="70.0" style="-fx-background-color: #19345D; -fx-background-radius: 20; -fx-cursor: hand;" text="Tìm" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>

                <Label fx:id="lblStatus" alignment="CENTER" maxWidth="1.7976931348623157E308" text="Thông báo trạng thái" visible="false" wrapText="true">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>

                <TableView fx:id="tableUsers" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: WHITE; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 1);" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="40.0" style="-fx-alignment: CENTER;" text="ID" />
                        <TableColumn fx:id="colUsername" prefWidth="90.0" text="Username" />
                        <TableColumn fx:id="colEmail" prefWidth="130.0" text="Email" />
                        <TableColumn fx:id="colRole" prefWidth="60.0" style="-fx-alignment: CENTER;" text="Role" />
                        <TableColumn fx:id="colAction" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Hành động" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <Label text="* Click đúp hoặc dùng nút Hành động để chỉnh sửa trạng thái" textFill="#7f8c8d" wrapText="true">
                    <font>
                        <Font name="System Italic" size="12.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </children>
</AnchorPane>