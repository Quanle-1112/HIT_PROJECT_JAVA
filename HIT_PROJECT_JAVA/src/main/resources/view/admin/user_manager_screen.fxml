<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="450.0" style="-fx-background-color: #ECECE7;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.admin.UserManagerController">
    <children>
        <AnchorPane prefHeight="60.0" prefWidth="450.0" style="-fx-background-color: #19345D;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Button fx:id="btnBack" layoutX="10.0" layoutY="13.0" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;" text="&lt;" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Button>
                <Label layoutX="50.0" layoutY="15.0" text="Quản Lý Người Dùng" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <VBox layoutX="15.0" layoutY="70.0" spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="70.0">
            <children>
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="txtSearch" prefHeight="40.0" promptText="Tìm tên hoặc email..." style="-fx-background-radius: 20; -fx-padding: 0 15; -fx-border-color: #BDC3C7; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <font><Font size="13.0" /></font>
                        </TextField>
                        <Button fx:id="btnSearch" mnemonicParsing="false" prefHeight="40.0" prefWidth="80.0" style="-fx-background-color: #19345D; -fx-background-radius: 20; -fx-cursor: hand;" text="Tìm" textFill="WHITE">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                    </children>
                </HBox>

                <TableView fx:id="tableUsers" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: WHITE; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 1);" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="40.0" style="-fx-alignment: CENTER;" text="ID" />
                        <TableColumn fx:id="colUsername" prefWidth="120.0" text="Username" />
                        <TableColumn fx:id="colRole" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Role" />
                        <TableColumn fx:id="colAction" prefWidth="170.0" style="-fx-alignment: CENTER;" text="Hành động" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <Label text="* Click đúp hoặc dùng nút Hành động để chỉnh sửa" textFill="#7f8c8d" wrapText="true">
                    <font><Font name="System Italic" size="12.0" /></font>
                </Label>
            </children>
        </VBox>
    </children>
</AnchorPane>