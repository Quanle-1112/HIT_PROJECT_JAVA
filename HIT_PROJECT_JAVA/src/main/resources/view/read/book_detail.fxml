<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="450.0" style="-fx-background-color: #ECECE7;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.read.BookDetailController">
    <children>
        <AnchorPane prefHeight="60.0" prefWidth="450.0" style="-fx-background-color: #19345D;">
            <children>
                <Button fx:id="backButton" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;" text="&lt;" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Button>
                <Label fx:id="headerTitle" layoutX="50.0" layoutY="15.0" prefHeight="30.0" prefWidth="350.0" text="Thông tin truyện" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #ECECE7; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #ECECE7;">
                    <padding>
                        <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
                    </padding>
                    <children>

                        <HBox alignment="TOP_CENTER" spacing="20.0">
                            <children>
                                <ImageView fx:id="bookImageView" fitHeight="200.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
                                    <effect>
                                        <DropShadow color="#0000004d" radius="10.0" />
                                    </effect>
                                </ImageView>
                                <VBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="bookName" text="Tên Truyện" textFill="#19345d" wrapText="true">
                                            <font>
                                                <Font name="System Bold" size="18.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="bookAuthor" text="Tác giả: ..." textFill="#555555" wrapText="true">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="bookStatus" text="Trạng thái: ..." textFill="#555555">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="bookCategory" text="Thể loại: ..." textFill="#555555" wrapText="true">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Button fx:id="readButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: #D35400; -fx-cursor: hand; -fx-background-radius: 20;" text="Đọc ngay" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Button>

                                <Button fx:id="readNewestButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: #19345D; -fx-cursor: hand; -fx-background-radius: 20;" text="Mới nhất" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Button>

                                <Button fx:id="favoriteButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="50.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand;" text="♡" textFill="#E74C3C">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets bottom="5.0" top="5.0" />
                            </VBox.margin>
                        </HBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Nội dung" textFill="#19345d">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <TextArea fx:id="descriptionArea" editable="false" prefHeight="100.0" style="-fx-background-color: transparent; -fx-control-inner-background: #ECECE7; -fx-text-fill: #333333;" wrapText="true" />
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <Label text="Danh sách chương" textFill="#19345d">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>

                                <VBox fx:id="chapterListContainer" spacing="8.0" />

                                <HBox alignment="CENTER" spacing="15.0" style="-fx-padding: 10 0 0 0;">
                                    <children>
                                        <Button fx:id="btnPrev" mnemonicParsing="false" style="-fx-background-color: #19345D; -fx-cursor: hand; -fx-background-radius: 5;" text="&lt; Trước" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Button>

                                        <HBox alignment="CENTER" spacing="5.0">
                                            <children>
                                                <Label text="Trang" textFill="#19345d">
                                                    <font>
                                                        <Font name="System Bold" size="14.0" />
                                                    </font>
                                                </Label>
                                                <TextField fx:id="pageInput" alignment="CENTER" prefHeight="30.0" prefWidth="50.0" style="-fx-background-radius: 5; -fx-border-color: #19345d; -fx-border-radius: 5;" text="1">
                                                    <font>
                                                        <Font name="System Bold" size="12.0" />
                                                    </font>
                                                </TextField>
                                                <Label fx:id="pageLabel" text="/ 1" textFill="#19345d">
                                                    <font>
                                                        <Font name="System Bold" size="14.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </HBox>

                                        <Button fx:id="btnNext" mnemonicParsing="false" prefHeight="30.0" style="-fx-background-color: #19345D; -fx-cursor: hand; -fx-background-radius: 5;" text="Sau &gt;" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>