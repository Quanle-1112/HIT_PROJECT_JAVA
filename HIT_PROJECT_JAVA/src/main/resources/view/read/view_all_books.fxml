<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="450.0" style="-fx-background-color: #ECECE7;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.read.ViewAllBooksController">
    <children>
        <AnchorPane prefHeight="60.0" prefWidth="450.0" style="-fx-background-color: #19345D;">
            <children>
                <Button fx:id="backButton" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;" text="&lt;" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Button>
                <Label fx:id="titleLabel" layoutX="50.0" layoutY="15.0" text="Danh Sách Truyện" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="listContainer" spacing="15.0" style="-fx-background-color: #ECECE7;">
                    <padding>
                        <Insets bottom="10.0" left="15.0" right="15.0" top="20.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER" prefHeight="60.0" prefWidth="450.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 0, -5, 0, 0);">
            <children>
                <Button fx:id="btnPrevious" mnemonicParsing="false" style="-fx-background-color: #19345D; -fx-cursor: hand; -fx-background-radius: 5;" text="&lt; Trước" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>

                <HBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Trang" textFill="#19345d">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextField fx:id="pageInput" alignment="CENTER" prefHeight="30.0" prefWidth="60.0" text="1" style="-fx-background-radius: 5; -fx-border-color: #19345d; -fx-border-radius: 5;">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </TextField>
                    </children>
                </HBox>

                <Button fx:id="btnNext" mnemonicParsing="false" style="-fx-background-color: #19345D; -fx-cursor: hand; -fx-background-radius: 5;" text="Sau &gt;" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>