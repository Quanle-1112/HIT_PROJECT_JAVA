<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="350.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.account.ChangeNameController">
    <children>
        <AnchorPane prefHeight="50.0" prefWidth="350.0" style="-fx-background-color: #19345D;">
            <children>
                <Label layoutX="14.0" layoutY="13.0" text="Đổi Tên Hiển Thị" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>

        <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="350.0" spacing="15.0" style="-fx-background-color: #ECECE7; -fx-background-radius: 0 0 8 8;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="Nhập tên hiển thị mới của bạn:" textFill="#333333">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>

                <TextField fx:id="newNameField" prefHeight="40.0" promptText="Tên mới..." style="-fx-background-radius: 5; -fx-border-color: #19345d; -fx-border-radius: 5;">
                    <font>
                        <Font size="14.0" />
                    </font>
                </TextField>

                <Label fx:id="errorLabel" text="Tên không được để trống!" textFill="RED" visible="false">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>

                <Button fx:id="btnSave" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: #19345D; -fx-cursor: hand; -fx-background-radius: 5;" text="Lưu thay đổi" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>

                <Button fx:id="btnCancel" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="35.0" style="-fx-background-color: transparent; -fx-border-color: #19345d; -fx-border-radius: 5; -fx-cursor: hand;" text="Hủy bỏ" textFill="#19345d">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </children>
</VBox>
