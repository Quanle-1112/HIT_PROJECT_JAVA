<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="450.0" style="-fx-background-color: #ECECE7;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.favorite.FavoriteScreenController">

    <top>
        <AnchorPane prefHeight="60.0" prefWidth="450.0" style="-fx-background-color: #19345D;" BorderPane.alignment="CENTER">
            <children>
                <Label layoutX="20.0" layoutY="15.0" text="Truyện Yêu Thích" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #ECECE7; -fx-background-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <VBox fx:id="listContainer" alignment="TOP_CENTER" spacing="12.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #DDDDDD; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="btnHome" mnemonicParsing="false" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="Home" textFill="#19345d">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button fx:id="btnHistory" mnemonicParsing="false" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="History" textFill="#19345d">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button fx:id="btnFavorite" mnemonicParsing="false" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="Favorite" textFill="#19345d">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            <Button fx:id="btnAI" mnemonicParsing="false" prefWidth="80.0" style="-fx-background-color: transparent;" text="ChatBox" textFill="#19345d">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
                <Button fx:id="btnAccount" mnemonicParsing="false" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="Account" textFill="#19345d">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </HBox>
    </bottom>
</BorderPane>
