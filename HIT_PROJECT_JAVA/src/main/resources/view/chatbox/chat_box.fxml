<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="450.0" style="-fx-background-color: #ECECE7;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.chatbox.ChatBoxController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-background-color: #19345D; -fx-padding: 0 15;">
            <children>
                <Label text="ChatBox" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" vbarPolicy="AS_NEEDED" BorderPane.alignment="CENTER">
            <content>
                <VBox fx:id="messageContainer" spacing="15.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <VBox BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #FFFFFF; -fx-padding: 10; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;">
                    <children>
                        <TextField fx:id="inputField" promptText="Nhập câu hỏi của bạn..." style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ccc; -fx-padding: 8 15;" HBox.hgrow="ALWAYS">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </TextField>
                        <Button fx:id="btnSend" mnemonicParsing="false" style="-fx-background-color: #19345D; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20;" text="Gửi">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                    </children>
                </HBox>

                <HBox alignment="CENTER" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #DDDDDD; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
                    <children>
                        <Button fx:id="btnHome" mnemonicParsing="false" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="Home" textFill="#19345d">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                        <Button fx:id="btnHistory" mnemonicParsing="false" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="History" textFill="#19345d">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                        <Button fx:id="btnFavorite" mnemonicParsing="false" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="Favorite" textFill="#19345d">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                        <Button fx:id="btnAI" mnemonicParsing="false" prefWidth="80.0" style="-fx-background-color: transparent;" text="ChatBox" textFill="#19345d">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnAccount" mnemonicParsing="false" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="Account" textFill="#19345d">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </bottom>
</BorderPane>
